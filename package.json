{
  "name": "@darylcecile/promise-queue",
  "version": "0.1.1",
  "description": "A promise queue, task queue with concurrency control, and retryable utility",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --format esm && tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "promise",
    "queue",
    "task-queue",
    "concurrency",
    "retry",
    "async"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darylcecile/promise-queue.git"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
